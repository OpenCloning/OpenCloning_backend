# Canonical local development defaults for running opencloning-db on the host.
# Runtime config is now required from env, so load this file before local CLI/API work.
# Load with: set -a && source .env.dev && set +a

export OPENCLONING_DB_URL=postgresql+psycopg://dbuser:dbpassword@localhost:5432/opencloning_dev
export OPENCLONING_JWT_SECRET=local-dev-only-jwt-secret-change-for-shared-envs

# Common local frontend origins.
export ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3002

# Keep test-only routes disabled in normal local development.
export OPENCLONING_TESTING=0

# Optional signup allowlist: set to 1 to require emails to be present in the DB whitelist.
# Manage entries with:
#   uv run opencloning-cli admin whitelist-add alice@lab.edu
#   uv run opencloning-cli admin whitelist-remove alice@lab.edu
# export OPENCLONING_REGISTRATION_WHITELIST_ENABLED=1

# Switch database (uncomment one):
# export OPENCLONING_DB_URL=postgresql+psycopg://dbuser:dbpassword@localhost:5432/opencloning_test
# export OPENCLONING_DB_URL=postgresql+psycopg://dbuser:dbpassword@localhost:5432/opencloning_e2e
# export OPENCLONING_TEST_DATABASE_URL=postgresql+psycopg://dbuser:dbpassword@localhost:5432/opencloning_test

# Disable login rate limiting:
# export OPENCLONING_RATE_LIMIT_ENABLED=0

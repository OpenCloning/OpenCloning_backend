# Canonical local development defaults for running opencloning-db on the host.
# Runtime config is now required from env, so load this file before local CLI/API work.
# Load with: set -a && source .env.dev && set +a

export OPENCLONING_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opencloning_dev
export OPENCLONING_OBJECT_STORAGE_ENDPOINT_URL=http://localhost:9000
export OPENCLONING_OBJECT_STORAGE_ACCESS_KEY_ID=opencloning-dev
export OPENCLONING_OBJECT_STORAGE_SECRET_ACCESS_KEY=opencloning-dev-secret
export OPENCLONING_OBJECT_STORAGE_BUCKET=opencloning-dev
export OPENCLONING_OBJECT_STORAGE_REGION=us-east-1
export OPENCLONING_OBJECT_STORAGE_FORCE_PATH_STYLE=1
export OPENCLONING_SEQUENCE_OBJECTS_PREFIX=sequences/
export OPENCLONING_SEQUENCING_OBJECTS_PREFIX=sequencing-files/
export OPENCLONING_JWT_SECRET=local-dev-only-jwt-secret-change-for-shared-envs

# Common local frontend origins.
export ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3002

# Keep test-only routes disabled in normal local development.
export OPENCLONING_TESTING=0

# Optional alternatives:
# OPENCLONING_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opencloning_test
# OPENCLONING_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opencloning_e2e
# OPENCLONING_TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opencloning_test
